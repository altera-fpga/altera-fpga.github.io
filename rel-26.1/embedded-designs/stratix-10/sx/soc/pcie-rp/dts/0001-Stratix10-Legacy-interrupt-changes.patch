+			cap-mmc-highspeed;
+			broken-cd;
+			bus-width = <0x04>;
+			clk-phase-sd-hs = <0x00 0x87>;
+			phandle = <0x15>;
+		};
+
+		nand-controller@ffb90000 {
+			#address-cells = <0x01>;
+			#size-cells = <0x00>;
+			compatible = "altr,socfpga-denali-nand";
+			reg = <0xffb90000 0x10000 0xffb80000 0x1000>;
+			reg-names = "nand_data\0denali_reg";
+			interrupts = <0x00 0x61 0x04>;
+			clocks = <0x08 0x3d 0x08 0x3e 0x08 0x3f>;
+			clock-names = "nand\0nand_x\0ecc";
+			resets = <0x07 0x25 0x07 0x2d>;
+			status = "disabled";
+			phandle = <0x28>;
