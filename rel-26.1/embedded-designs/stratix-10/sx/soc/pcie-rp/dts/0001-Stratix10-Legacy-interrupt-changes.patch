+			#size-cells = <0x00>;
+			compatible = "altr,socfpga-dw-mshc";
+			reg = <0xff808000 0x1000>;
+			interrupts = <0x00 0x60 0x04>;
+			fifo-depth = <0x400>;
+			resets = <0x07 0x27>;
+			reset-names = "reset";
+			clocks = <0x08 0x2c 0x08 0x39>;
+			clock-names = "biu\0ciu";
+			iommus = <0x09 0x05>;
+			altr,sysmgr-syscon = <0x0a 0x28 0x04>;
